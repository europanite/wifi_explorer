{
  "expo": {
    "name": "wifi-gps-logger",
    "slug": "wifi-gps-logger",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "plugins": [
      "react-native-wifi-reborn"
    ],
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "NEARBY_WIFI_DEVICES"
      ],
      "package": "com.europanite.wifigpslogger"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow the app to read your location while tracking nearby Wi-Fi networks.",
        "NSLocalNetworkUsageDescription": "Allow the app to inspect nearby Wi-Fi information on supported builds."
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "62d470b3-d055-457a-991d-c2d522ad7ff2"
      }
    }
  }
}
